# Copy to .env and fill in real values.

# This site's own URL (Next.js landing page)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Link to the Expo app (used for "Get started" / "Sign in" buttons)
NEXT_PUBLIC_APP_URL=http://localhost:8081

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only: required for the mentor apply API route (/api/mentor/apply)
# Find this in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Server-only: required for the Resend sync webhook (/api/webhooks/resend-sync)
# Find this in: Resend Dashboard → API Keys / Audiences
RESEND_API_KEY=re_your_api_key_here
RESEND_AUDIENCE_ID=your_audience_id_here

# Shared secret checked against the x-webhook-secret header sent by the
# Supabase Database Webhook. Generate any random string for this.
SUPABASE_WEBHOOK_SECRET=your_webhook_shared_secret_here
