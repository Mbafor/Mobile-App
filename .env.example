# Copy to .env and replace with values from Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Expo EAS project ID for remote push token registration
EXPO_PUBLIC_EAS_PROJECT_ID=

# Paystack — public key for client; secret key goes in Supabase Edge Function secrets
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# URL of the Next.js marketing/landing site (web users are redirected here when unauthenticated)
EXPO_PUBLIC_LANDING_URL=https://olivesforum.com
